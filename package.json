{
  "name": "snake-io",
  "version": "1.0.0",
  "description": "Multiplayer snake.io game with WebSocket networking",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "tunnel": "lt --port 3000 --subdomain snakeio-${SUBDOMAIN:-host}",
    "host": "concurrently \"npm start\" \"npm run tunnel\""
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "localtunnel": "^2.0.2"
  }
}
